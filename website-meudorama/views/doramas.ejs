<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<div class="container-fluid p-0 position-relative d-flex align-items-center" style="height: 200px; overflow: hidden;">
    <img src="imgs/banner-titulo.png" class="position-absolute w-100 h-100" style="object-fit: cover; z-index: 1;" alt="Banner">
    
   <div class="container h-100 position-relative d-flex align-items-center justify-content-between" style="z-index: 2;">

      <div class="d-flex flex-column">
         <h1 class="text-white fw-bold m-0">Todos os Doramas</h1>
         <nav aria-label="breadcrumb">
            <ol class="breadcrumb m-0">
               <li class="breadcrumb-item"><a href="/">Home</a></li>
               <li class="breadcrumb-item active" aria-current="page">Doramas</li>
            </ol>
         </nav>
      </div>

      <div class="d-flex align-items-end" style="min-width: 250px;">
         <select class="form-select form-select-sm" aria-label="Filtrar doramas">
            <option selected>Filtrar por gênero</option>
            <option value="1">Comédia Romântica</option>
            <option value="2">Ação</option>
            <option value="3">Drama</option>
         </select>
      </div>

   </div>
</div>
<section class="container mt-5">

    <div class="row g-4"> <% doramas.forEach(function(dorama) { %>
        <div class="col-12 col-xl-6"> 

            <div class="card h-100 shadow-sm overflow-hidden">
                <div class="row g-0 h-100">
                    <div class="col-4">
                        <img src="<%= dorama.imagem %>" 
                        class="img-fluid h-100" 
                        alt="<%= dorama.nome %>" 
                        style="object-fit: cover; min-height: 250px;">
                    </div>

                    <div class="col-8">
                        <div class="card-body d-flex flex-column h-100">
                            <h5 class="card-title fw-bold"><%= dorama.nome %></h5>

                            <p class="card-text flex-grow-1" style="font-size: 0.9rem;">
                            <%= dorama.descricao %>
                            </p>

                            <div class="mt-auto">
                                <p class="card-text mb-2">
                                <small class="text-muted">Gênero: <%= dorama.genero %></small>
                                </p>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-danger">
                                    <img src="/imgs/icons/heart.png" width="14"> 255
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning text-dark">
                                    <img src="/imgs/icons/star.png" width="14"> 913
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>  
                </div>
            </div>  
        </div>
        <% }); %>
    </div>
</section>

<%- include ('partials/footer.ejs') %>