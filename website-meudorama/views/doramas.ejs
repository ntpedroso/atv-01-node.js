<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<section class="container mt-5">
    
    <h1 class="mb-4">Doramas</h1>

    <div class="row g-4"> <% doramas.forEach(function(dorama) { %>
        <div class="col-12 col-xl-6"> 

            <div class="card h-100 shadow-sm overflow-hidden">
                <div class="row g-0 h-100">
                    <div class="col-4">
                        <img src="<%= dorama.imagem %>" 
                        class="img-fluid h-100" 
                        alt="<%= dorama.nome %>" 
                        style="object-fit: cover; min-height: 250px;">
                    </div>

                    <div class="col-8">
                        <div class="card-body d-flex flex-column h-100">
                            <h5 class="card-title fw-bold"><%= dorama.nome %></h5>

                            <p class="card-text flex-grow-1" style="font-size: 0.9rem;">
                            <%= dorama.descricao %>
                            </p>

                            <div class="mt-auto">
                                <p class="card-text mb-2">
                                <small class="text-muted">Gênero: <%= dorama.genero %></small>
                                </p>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-danger">
                                    <img src="/imgs/icons/heart.png" width="14"> 255
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning text-dark">
                                    <img src="/imgs/icons/star.png" width="14"> 913
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>  
                </div>
            </div>  
        </div>
        <% }); %>
    </div>
</section>

<%- include ('partials/footer.ejs') %>