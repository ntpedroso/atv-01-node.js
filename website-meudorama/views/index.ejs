<%- include ('partials/header.ejs')%>
<%- include ('partials/navbar.ejs') %>

<section>
  <div id="carouselMeuDorama" class="carousel slide" data-bs-ride="carousel">
    
    <div class="carousel-indicators">
      <button type="button" data-bs-target="#carouselMeuDorama" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
      <button type="button" data-bs-target="#carouselMeuDorama" data-bs-slide-to="1" aria-label="Slide 2"></button>
      <button type="button" data-bs-target="#carouselMeuDorama" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>

    <div class="carousel-inner">
      <div class="carousel-item active" data-bs-interval="4000"> <img src="imgs/banner-1.png" class="d-block w-100" alt="Beijo Explosivo">
        <div class="carousel-caption">
          <h5 class="fw-bold">KDRAMA DO MOMENTO</h5>
          <p>Conheça Beijo Explosivo: o queridinho do momento.</p>
        </div>
      </div>

      <div class="carousel-item" data-bs-interval="5000">
        <img src="imgs/banner-2.png" class="d-block w-100" alt="Vossa Majestade">
        <div class="carousel-caption">
          <h5 class="fw-bold">NOVA ESTRELA EM ASCENSÃO</h5>
          <p>Descubra quem é o talento coreano que está roubando a cena em Bon Appétit, Vossa Majestade.</p>
        </div>
      </div>

      <div class="carousel-item" data-bs-interval="5000">
        <img src="imgs/banner-3.png" class="d-block w-100" alt="Explorar">
        <div class="carousel-caption">
          <h5 class="fw-bold">UM CLÁSSICO HILÁRIO!</h5>
          <p>Prepare-se para rir sem parar com a troca de corpos mais inusitada da dinastia Joseon em "Sr. Rainha".</p>
        </div>
      </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#carouselMeuDorama" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselMeuDorama" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Próximo</span>
    </button>
  </div>
</section>

